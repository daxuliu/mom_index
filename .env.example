# 宝妈指数 - 环境变量模板
# 复制到 .env 并填入真实值（.env 已在 .gitignore 中，不会泄漏到 git）

# ============================================================
# DeepSeek LLM（情绪分析 + 指数解读）
# 申请地址: https://platform.deepseek.com/api_keys
# 新用户送 500 万 token 免费额度（30 天有效）
# ============================================================
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型名（可选，默认 deepseek-chat 走 V4-Flash alias）
# 2026-07-24 后 deepseek-chat 会弃用，建议显式设：
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-chat

# 自定义 API base URL（可选，用于走代理或兼容服务）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 单次调用超时（秒）
DEEPSEEK_TIMEOUT=30

# ============================================================
# 小红书采集（可选，pipeline.py 用）
# 申请地址: https://www.rnode.io/
# ============================================================
# RNODE_API_KEY=

# ============================================================
# 部署相关
# ============================================================
# API_PORT=8766
# PYTHONUNBUFFERED=1
